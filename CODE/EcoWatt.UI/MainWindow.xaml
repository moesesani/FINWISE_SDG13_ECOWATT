<Window x:Class="EcoWatt.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EcoWatt - High Voltage Dashboard" Height="850" Width="600" 
        WindowStartupLocation="CenterScreen" Background="#0B0E14">

    <Window.Resources>
        <Style x:Key="EnergyCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#161B22"/>
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,25"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="25" Color="#00D4FF" ShadowDepth="0" Opacity="0.1"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#0D1117"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="CaretBrush" Value="#FFD60A"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Ellipse Fill="#00D4FF" Width="300" Height="300" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-150,-150,0" Opacity="0.05" IsHitTestVisible="False"/>

        <ScrollViewer VerticalScrollBarVisibility="Hidden">
            <StackPanel Margin="30">

                <DockPanel Margin="0,0,0,30">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="⚡ ECOWATT" FontSize="32" FontWeight="ExtraBlack" Foreground="#FFD60A">
                            <TextBlock.Effect>
                                <DropShadowEffect BlurRadius="12" Color="#FFD60A" Opacity="0.5" ShadowDepth="0"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <TextBlock Text="APPLIANCES ENERGY TRACKER SYSTEM" FontSize="10" Foreground="#00D4FF" FontWeight="Bold" Margin="2,0,0,0"/>
                    </StackPanel>

                    <Button x:Name="btnLogout" Content="Logout" Click="btnLogout_Click" 
                            DockPanel.Dock="Right" HorizontalAlignment="Right"
                            Width="100" Height="32" Background="#FF4D4D" Foreground="White" 
                            FontWeight="Bold" BorderThickness="0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="16"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </DockPanel>

                <Border Style="{StaticResource EnergyCardStyle}" BorderBrush="#FFD60A" BorderThickness="0,2,0,0">
                    <StackPanel>
                        <TextBlock Text="POWER INPUT CONTROL" FontSize="14" FontWeight="Bold" Foreground="#FFD60A" Margin="0,0,0,18"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="DEVICE NAME" FontSize="10" Foreground="#8B949E" Margin="2,0,0,5" FontWeight="Bold"/>
                                <TextBox x:Name="txtAppliance"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                <TextBlock Text="WATTAGE (W)" FontSize="10" Foreground="#8B949E" Margin="2,0,0,5" FontWeight="Bold"/>
                                <TextBox x:Name="txtWattage"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="DURATION (H)" FontSize="10" Foreground="#8B949E" Margin="2,0,0,5" FontWeight="Bold"/>
                                <TextBox x:Name="txtHours"/>
                            </StackPanel>
                        </Grid>

                        <Button x:Name="btnSave" Content="INITIALIZE POWER" Click="btnSave_Click" 
                                Background="#FFD60A" Foreground="Black" Height="45" 
                                FontWeight="Black" Margin="0,20,0,0" BorderThickness="0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </Button.Resources>
                            <Button.Effect>
                                <DropShadowEffect BlurRadius="15" Color="#FFD60A" Opacity="0.3" ShadowDepth="0"/>
                            </Button.Effect>
                        </Button>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource EnergyCardStyle}">
                    <StackPanel>
                        <TextBlock Text="VOLTAGE LOAD VISUALIZER" FontSize="14" FontWeight="Bold" Foreground="#00D4FF" Margin="0,0,0,20"/>
                        <ItemsControl x:Name="chartControl" Height="160">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="12,0" VerticalAlignment="Bottom">
                                        <Border Width="35" Height="{Binding Wattage}" MaxHeight="120" CornerRadius="6,6,0,0">
                                            <Border.Background>
                                                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                                    <GradientStop Color="#00D4FF" Offset="0"/>
                                                    <GradientStop Color="#0055FF" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="12" Color="#00D4FF" Opacity="0.6" ShadowDepth="0"/>
                                            </Border.Effect>
                                        </Border>
                                        <TextBlock Text="{Binding ApplianceName}" FontSize="10" Foreground="#8B949E" Margin="0,8,0,0"
                                                   TextAlignment="Center" FontWeight="Medium"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource EnergyCardStyle}">
                    <StackPanel>
                        <TextBlock Text="SYSTEM ENERGY LOGS" FontSize="14" FontWeight="Bold" Foreground="#8B949E" Margin="0,0,0,15"/>
                        <DataGrid x:Name="dgEnergyLogs" Height="250" AutoGenerateColumns="False" 
                                  CanUserAddRows="False" Background="Transparent" BorderThickness="0"
                                  GridLinesVisibility="None" RowBackground="#161B22" Foreground="White"
                                  AlternatingRowBackground="#1C2128" HeadersVisibility="Column">
                            <DataGrid.Resources>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#00D4FF"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Padding" Value="10"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="#30363D"/>
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="CORE DEVICE" Binding="{Binding ApplianceName}" Width="*"/>
                                <DataGridTextColumn Header="VOLTS/WATTS" Binding="{Binding Wattage}" Width="120"/>
                                <DataGridTemplateColumn Header="COMMAND" Width="140">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="EDIT" Click="btnEdit_Click" Margin="2" Padding="10,4" Background="#30363D" Foreground="#00D4FF" BorderThickness="0" FontSize="10" FontWeight="Bold"/>
                                                <Button Content="DELETE" Click="btnDelete_Click" Margin="2" Padding="10,4" Background="#30363D" Foreground="#FF4D4D" BorderThickness="0" FontSize="10" FontWeight="Bold"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource EnergyCardStyle}" BorderBrush="#00D4FF" BorderThickness="0,0,0,3">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="DATA TELEMETRY BACKUP" FontSize="14" FontWeight="Bold" Foreground="#00D4FF" Margin="0,0,0,5"/>
                            <TextBlock Text="Generate a JSON snapshot of all recorded energy logs for external analysis." 
                                       Foreground="#8B949E" FontSize="10" TextWrapping="Wrap" Margin="0,0,20,0"/>
                        </StackPanel>

                        <Button x:Name="btnExport" Grid.Column="1" Content="EXPORT TO JSON" Click="btnExport_Click"
                                Width="140" Height="40" Background="#161B22" Foreground="#00D4FF" 
                                BorderBrush="#00D4FF" BorderThickness="1" FontWeight="Bold" FontSize="11" Cursor="Hand">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="4"/>
                                </Style>
                            </Button.Resources>
                            <Button.Effect>
                                <DropShadowEffect BlurRadius="10" Color="#00D4FF" Opacity="0.2" ShadowDepth="0"/>
                            </Button.Effect>
                        </Button>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>