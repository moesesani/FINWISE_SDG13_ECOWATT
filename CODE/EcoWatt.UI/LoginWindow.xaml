<Window x:Class="EcoWatt.UI.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EcoWatt - System Access" Height="500" Width="380" 
        WindowStartupLocation="CenterScreen" Background="#0B0E14"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="ElectricInputStyle" TargetType="Control">
            <Setter Property="Background" Value="#161B22"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Height" Value="38"/>
        </Style>

        <Style x:Key="NeonButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FFD60A"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="35">
        <Ellipse Fill="#00D4FF" Width="200" Height="200" Margin="-100,-100,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" Opacity="0.05" IsHitTestVisible="False"/>

        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="   ⚡ ECOWATT" FontSize="34" FontWeight="ExtraBlack" Foreground="#FFD60A">
                <TextBlock.Effect>
                    <DropShadowEffect BlurRadius="15" Color="#FFD60A" Opacity="0.4" ShadowDepth="0"/>
                </TextBlock.Effect>
            </TextBlock>
            <TextBlock Text="                                  SECURE ENERGY ACCESS" FontSize="10" Foreground="#00D4FF" FontWeight="Bold"/>

            <TextBlock Text="OPERATOR ID" FontSize="10" Foreground="#8B949E" FontWeight="Bold" Margin="2,0,0,5"/>
            <TextBox x:Name="txtUsername" Style="{StaticResource ElectricInputStyle}" VerticalContentAlignment="Center" BorderThickness="1"/>

            <TextBlock Text="ACCESS CODE" FontSize="10" Foreground="#8B949E" FontWeight="Bold" Margin="2,15,0,5"/>
            <Grid>
                <PasswordBox x:Name="txtPassword" Style="{StaticResource ElectricInputStyle}" VerticalContentAlignment="Center" Visibility="Visible" BorderThickness="1"/>
                <TextBox x:Name="txtVisiblePassword" Style="{StaticResource ElectricInputStyle}" VerticalContentAlignment="Center" Visibility="Collapsed" BorderThickness="1"/>
            </Grid>

            <CheckBox x:Name="chkShowPassword" Content="Show Access Code" Margin="2,8,0,0" Foreground="#8B949E" FontSize="10"
                      Checked="ChkShowPassword_Checked" Unchecked="ChkShowPassword_Unchecked"/>

            <TextBlock x:Name="lblMessage" Text="" Foreground="#FF4D4D" FontSize="11" Margin="0,15,0,0" TextWrapping="Wrap" HorizontalAlignment="Center" FontWeight="Medium"/>

            <Button x:Name="btnLogin" Content="INITIALIZE LOGIN" Margin="0,20,0,10" Height="45" 
                    Style="{StaticResource NeonButtonStyle}" Click="BtnLogin_Click">
                <Button.Effect>
                    <DropShadowEffect BlurRadius="15" Color="#FFD60A" Opacity="0.3" ShadowDepth="0"/>
                </Button.Effect>
            </Button>

            <Button x:Name="btnRegister" Content="CREATE NEW OPERATOR" Height="35" 
                    Background="Transparent" BorderBrush="#30363D" Foreground="#00D4FF" 
                    FontWeight="SemiBold" Click="BtnRegister_Click" BorderThickness="1">
                <Button.Resources>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="CornerRadius" Value="8"/>
                    </Style>
                </Button.Resources>
            </Button>

            <TextBlock Text="ECOWATT Final Project © 2026" FontSize="9" Foreground="#30363D" HorizontalAlignment="Center" Margin="0,30,0,0" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>