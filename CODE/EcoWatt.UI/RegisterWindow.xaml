<Window x:Class="EcoWatt.UI.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EcoWatt - System Registration" Height="520" Width="380" 
        WindowStartupLocation="CenterScreen" Background="#0B0E14"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="ElectricInputStyle" TargetType="Control">
            <Setter Property="Background" Value="#161B22"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Height" Value="38"/>
        </Style>

        <Style x:Key="ThunderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FFD60A"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="ExtraBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="35">
        <Ellipse Fill="#FFD60A" Width="200" Height="200" Margin="0,-120,-120,0" VerticalAlignment="Top" HorizontalAlignment="Right" Opacity="0.03" IsHitTestVisible="False"/>

        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="⚡ ECOWATT" FontSize="30" FontWeight="ExtraBlack" Foreground="#FFD60A" HorizontalAlignment="Center">
                <TextBlock.Effect>
                    <DropShadowEffect BlurRadius="12" Color="#FFD60A" Opacity="0.4" ShadowDepth="0"/>
                </TextBlock.Effect>
            </TextBlock>
            <TextBlock Text="NEW OPERATOR REGISTRATION" FontSize="10" Foreground="#00D4FF" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,5,0,30"/>

            <TextBlock Text="SET OPERATOR USERNAME" FontSize="9" Foreground="#8B949E" FontWeight="Bold" Margin="2,0,0,5"/>
            <TextBox x:Name="txtRegUsername" Style="{StaticResource ElectricInputStyle}" VerticalContentAlignment="Center" BorderThickness="1"/>

            <TextBlock Text="CREATE ACCESS CODE" FontSize="9" Foreground="#8B949E" FontWeight="Bold" Margin="2,15,0,5"/>
            <Grid>
                <PasswordBox x:Name="txtRegPassword" Style="{StaticResource ElectricInputStyle}" VerticalContentAlignment="Center" Visibility="Visible" BorderThickness="1"/>
                <TextBox x:Name="txtRegVisiblePassword" Style="{StaticResource ElectricInputStyle}" VerticalContentAlignment="Center" Visibility="Collapsed" BorderThickness="1"/>
            </Grid>

            <CheckBox x:Name="chkShowPassword" Content="Show Access Code" Margin="2,8,0,0" Foreground="#8B949E" FontSize="10"
                      Checked="ChkShowPassword_Checked" Unchecked="ChkShowPassword_Unchecked"/>

            <TextBlock x:Name="lblRegMessage" Text="" Foreground="#FF4D4D" FontSize="11" Margin="0,15,0,0" TextAlignment="Center" TextWrapping="Wrap" FontWeight="Medium"/>

            <Button Content="AUTHORIZE ACCOUNT" Click="BtnRegister_Click" Margin="0,20,0,10" Height="45" 
                    Style="{StaticResource ThunderButtonStyle}">
                <Button.Effect>
                    <DropShadowEffect BlurRadius="15" Color="#FFD60A" Opacity="0.3" ShadowDepth="0"/>
                </Button.Effect>
            </Button>

            <Button Content="RETURN TO LOGIN" Click="BtnBack_Click"
                    Background="Transparent" Foreground="#00D4FF" BorderThickness="0" 
                    FontSize="11" FontWeight="Bold" Cursor="Hand" Margin="0,10,0,0"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,30,0,0">
                <Rectangle Width="30" Height="1" Fill="#30363D" VerticalAlignment="Center"/>
                <TextBlock Text=" GRID SECURE " FontSize="8" Foreground="#30363D" FontWeight="Bold"/>
                <Rectangle Width="30" Height="1" Fill="#30363D" VerticalAlignment="Center"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>